# ====================
# Environment Template
# ====================
# Copy this file to .env and fill in your actual values
# IMPORTANT: .env file is ignored by git - never commit real secrets!

# Database
DATABASE_URL=sqlite:///./doc_management.db

# Security - JWT Configuration
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# REQUIRED: Minimum 32 characters
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS

# Default Admin User (created on first startup)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_ADMIN_EMAIL=admin@example.com

# Ollama 本地模型
# 預設連線至 http://127.0.0.1:11434，請先安裝並啟動 ollama，再拉取需要的模型
# 例如：ollama pull llama3.2  /  ollama pull llava  /  ollama pull all-minilm
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava
OLLAMA_EMBED_MODEL=all-minilm
OLLAMA_KEEP_ALIVE=5m
OLLAMA_TIMEOUT=120  # 秒

# Storage configuration
FILE_STORAGE_DIR=./storage
PDF_STORAGE_DIR=./storage/documents
PDF_TEMP_DIR=./storage/tmp
FAISS_INDEX_PATH=./storage/faiss_index.bin
